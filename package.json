{
  "name": "securechat",
  "version": "1.0.0",
  "description": "End-to-end encrypted chat using public/private wallet keys (X25519 + XSalsa20 + Poly1305).",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=spec \"tests/**/*.test.js\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "socket.io-client": "^4.8.1"
  }
}
