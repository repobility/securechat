{
  "name": "securechat",
  "version": "1.0.0",
  "description": "End-to-end encrypted chat using public/private wallet keys (X25519 + XSalsa20 + Poly1305).",
  "private": true,
  "license": "MIT",
  "author": "Mohammed Aljefairi <mohammedaljefairi@gmail.com>",
  "homepage": "https://github.com/repobility/securechat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repobility/securechat.git"
  },
  "bugs": {
    "url": "https://github.com/repobility/securechat/issues"
  },
  "keywords": [
    "e2e",
    "end-to-end-encryption",
    "chat",
    "messenger",
    "x25519",
    "nacl",
    "tweetnacl",
    "wallet",
    "websocket",
    "socket.io"
  ],
  "main": "server.js",
  "files": [
    "server.js",
    "src/",
    "public/",
    "README.md",
    "SECURITY.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=spec \"tests/**/*.test.js\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "socket.io-client": "^4.8.1"
  }
}
